body {
// 1. Скрываем картинки-логотипы (и новые, и старые классы).
// Это полностью отключает иконку сейфа на странице входа и внутри приложения.
a[href='#/'] bit-icon,
svg[viewBox="0 0 290 60"],
.tw-fill-marketing-logo,
.logo-inline,
.navbar-brand img,
.navbar-brand svg {
display: none !important;
}

// 2. Рисуем красивый текст "TechOps" на странице входа (новый Tailwind интерфейс).
// Мы привязываемся к ссылке, которая раньше оборачивала картинку.
a[href='#/']::after {
content: "TechOps" !important;
display: block !important;
font-family: 'Inter', 'Segoe UI', system-ui, sans-serif !important; // Современные шрифты
font-size: 44px !important; // Крупно, как логотип
font-weight: 800 !important; // Очень жирное начертание (ExtraBold)
color: #0d6efd !important; // Сочный, профессиональный технологичный синий цвет
letter-spacing: -1.5px !important; // Слегка сдвигаем буквы для плотности логотипа
line-height: 1 !important;
margin-bottom: 25px !important; // Отступ от формы входа
}

// 3. Рисуем текст "TechOps" внутри самого Vaultwarden (старый Bootstrap-интерфейс).
// Это логотип, который будет виден пользователю слева сверху, когда он уже вошел.
.navbar-brand::after {
content: "TechOps" !important;
display: inline-block !important;
font-family: 'Inter', 'Segoe UI', system-ui, sans-serif !important;
font-size: 24px !important;
font-weight: 800 !important;
color: #0d6efd !important;
letter-spacing: -1px !important;
margin-left: 5px !important;
}
}

// 4. Скрываем текст "Vaultwarden Web 2026.1.1..." в самом низу страницы
footer {
display: none !important;
}

// 5. Обработка темной темы: делаем шрифт логотипа белым
html.theme_dark {
a[href='#/']::after,
.navbar-brand::after {
color: #ffffff !important;
}
}