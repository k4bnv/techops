body {
    // Aggressively replace the logo on the login page and inside the vault
    .navbar-brand img, .navbar-brand svg {
        // Заменяем оригинальную картинку на наш логотип
        content: url('/images/logo-dark@2x.png') !important;
        // Задаем оригинальные размеры или подходящие под navbar
        max-width: 100% !important;
        max-height: 50px !important; // Ограничиваем высоту для навбара
        width: auto !important;
        height: auto !important;
        background-color: transparent !important; // Убеждаемся что нет фона
    }

    // Дополнительная очистка фона, если бренд-контейнер имеет свой фон
    .navbar-brand {
        background: transparent !important;
    }

    // Если Vaultwarden где-то использует классы margin, убираем дефолтные SVG
    .logo-inline {
        content: url('/images/logo-dark@2x.png') !important;
        max-height: 50px !important;
        width: auto !important;
        height: auto !important;
        background-color: transparent !important;
    }
}
