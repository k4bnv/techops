/* ===== TECHOPS CUSTOM BRANDING ===== */

/* 1. Hide all image/SVG based logos */
a[href='#/'] bit-icon,
svg[viewBox="0 0 290 60"],
.tw-fill-marketing-logo,
.logo-inline,
.navbar-brand img,
.navbar-brand svg {
display: none !important;
}

/* 2. Inject "TechOps" text on the login page (new Tailwind Bitwarden interface) */
a[href='#/']::after {
content: "TechOps" !important;
display: block !important;
font-family: 'Inter', 'Segoe UI', system-ui, sans-serif !important;
font-size: 44px !important;
font-weight: 800 !important;
color: #0d6efd !important;
letter-spacing: -1.5px !important;
line-height: 1 !important;
margin-bottom: 25px !important;
}

/* 3. Inject "TechOps" text in the main vault navbar (logged in view) */
.navbar-brand::after {
content: "TechOps" !important;
display: inline-block !important;
font-family: 'Inter', 'Segoe UI', system-ui, sans-serif !important;
font-size: 24px !important;
font-weight: 800 !important;
color: #0d6efd !important;
letter-spacing: -1px !important;
margin-left: 5px !important;
}

/* 4. Hide Vaultwarden footer disclaimer */
footer {
display: none !important;
}

/* 5. Dark theme: make the TechOps logo text white */
html.theme_dark a[href='#/']::after,
html.theme_dark .navbar-brand::after {
color: #ffffff !important;
}