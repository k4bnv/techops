/* ============================================================
TechOps Vaultwarden Custom Branding
Файл: templates/scss/user.vaultwarden.scss.hbs
Монтируется через TEMPLATES_FOLDER=/data/templates/scss
============================================================ */

/* --- Скрываем стандартный логотип Bitwarden/Vaultwarden --- */
img[src*="logo"],
img[src*="bitwarden"],
img[src*="vaultwarden"],
.logo img,
app-logo img,
bit-icon[name="bwi-logo"] svg {
opacity: 0 !important;
width: 0 !important;
height: 0 !important;
}

/* --- Заменяем логотип TechOps --- */
.logo,
app-logo,
[class*="logo-container"] {
display: block !important;
background-image: url("/images/techops/logo.png") !important;
background-repeat: no-repeat !important;
background-size: contain !important;
background-position: center left !important;
min-width: 200px !important;
min-height: 50px !important;
}

/* --- Цветовая схема TechOps --- */
:root {
--color-primary-300: #4db8ff;
--color-primary-600: #0078d4;
--color-primary-700: #005a9e;
}

/* Кнопки */
.btn-primary,
button[type="submit"],
[class*="btn-primary"] {
background: linear-gradient(135deg, #0066cc 0%, #00aaff 100%) !important;
border-color: #0066cc !important;
}
.btn-primary:hover { background: linear-gradient(135deg, #0055aa 0%, #0099ee 100%) !important; }

/* Navbar/Header */
nav, .navbar, app-header, [class*="header"] {
background-color: #0A1628 !important;
border-bottom: 1px solid #1a2d4a !important;
}

/* Прячем Powered by Vaultwarden */
small:has(a[href*="vaultwarden"]),
small:has(a[href*="bitwarden"]),
[class*="powered-by"] { display: none !important; }